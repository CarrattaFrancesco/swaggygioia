# ──────────────────────────────────────────────
# Portfolio originals (keep .webp only)
# ──────────────────────────────────────────────
data/IMG/**/*.png
data/IMG/**/*.jpeg
data/IMG/**/*.jpg
data/IMG/**/*.pdf

# Video originals (keep compressed versions)
data/IMG/**/*.mov
data/IMG/**/*.avi
data/IMG/**/*.mkv
# Exclude original mp4s but keep _compressed.mp4 via negation
data/IMG/**/*.mp4
!data/IMG/**/*_compressed.mp4

# ──────────────────────────────────────────────
# HDR environment maps (feature disabled in code)
# ──────────────────────────────────────────────
data/models/*.hdr

# ──────────────────────────────────────────────
# Deprecated / old code
# ──────────────────────────────────────────────
outdated/

# ──────────────────────────────────────────────
# OS generated files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ──────────────────────────────────────────────
# Editor / IDE folders
# ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ──────────────────────────────────────────────
# Python bytecode
# ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.swp
*.swo
*~
*.log
*TEMP_MPY*
